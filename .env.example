APP_ENV=dev
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
DB_PATH=chatbot.db

# Twilio inbound/outbound
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
PUBLIC_WHATSAPP_NUMBER=+14155238886
ENABLE_TWILIO_SIGNATURE_VALIDATION=false

# Admin endpoint security (human handoff)
ADMIN_API_KEY=change_this_to_a_long_random_secret

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Business settings
COMPANY_NAME=Tu Empresa
FAQ_MATCH_THRESHOLD=0.78
FAQ_MIN_SIMILARITY_FOR_GEMINI=0.35

# Optional webhook to notify human team when escalation is triggered
HUMAN_NOTIFICATION_WEBHOOK=
